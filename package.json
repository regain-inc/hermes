{
  "name": "@regain/hermes",
  "version": "1.0.2",
  "description": "TypeScript types, validation, and utilities for the Hermes clinical supervision protocol",
  "type": "module",
  "main": "./dist/index.js",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "bun": "./src/index.ts",
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    },
    "./schema": {
      "bun": "./src/schema/index.ts",
      "types": "./dist/schema/index.d.ts",
      "import": "./dist/schema/index.js"
    },
    "./fixtures": {
      "bun": "./src/fixtures/index.ts",
      "types": "./dist/fixtures/index.d.ts",
      "import": "./dist/fixtures/index.js"
    },
    "./package.json": "./package.json"
  },
  "files": ["dist", "src", "LICENSE", "README.md", "CHANGELOG.md"],
  "sideEffects": false,
  "scripts": {
    "build": "bun run build:js && bun run build:types",
    "build:js": "bun build ./src/index.ts --outdir ./dist --target node --format esm && bun build ./src/index.ts --outfile ./dist/index.cjs --target node --format cjs",
    "build:types": "tsc --emitDeclarationOnly --outDir dist",
    "dev": "bun --watch src/index.ts",
    "test": "bun test",
    "lint": "biome check .",
    "lint:fix": "biome check --write .",
    "format": "biome format --write .",
    "typecheck": "tsc --noEmit",
    "prepublishOnly": "bun run lint && bun run typecheck && bun run test && bun run build",
    "prepare": "git config core.hooksPath .githooks || true",
    "check": "bun run lint && bun run build:types && bun test",
    "prepack": "bun run build"
  },
  "devDependencies": {
    "@biomejs/biome": "^1.9.0",
    "@types/bun": "latest",
    "ajv": "^8.17.1",
    "ajv-formats": "^3.0.1",
    "typescript": "^5.7.0"
  },
  "peerDependencies": {
    "typescript": "^5.0.0"
  },
  "peerDependenciesMeta": {
    "typescript": {
      "optional": true
    }
  },
  "keywords": [
    "hermes",
    "clinical",
    "supervision",
    "healthcare",
    "ai-safety",
    "protocol",
    "typescript",
    "validation",
    "json-schema",
    "epistemology",
    "medical",
    "regain"
  ],
  "author": "Regain Inc. <engineering@regain.health>",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/regain-inc/hermes.git"
  },
  "bugs": {
    "url": "https://github.com/regain-inc/hermes/issues"
  },
  "homepage": "https://github.com/regain-inc/hermes#readme",
  "engines": {
    "node": ">=18.0.0"
  },
  "publishConfig": {
    "access": "public",
    "registry": "https://registry.npmjs.org/"
  }
}
